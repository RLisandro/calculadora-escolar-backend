      "url": "{{ _.base_url }}/professores/me",
      "headers": [{ "name": "Authorization", "value": "Bearer {{ _.token }}" }],
      "body": {}
    },
    {
      "_id": "req_prof_update",
      "_type": "request",
      "parentId": "fld_professor",
