{
  "name": "calculadora-escolar-backend",
  "version": "2.0.0",
  "description": " Gestão de Carga Horária Escolar ",
  "main": "dist/server.js",
  "packageManager": "npm@9.0.0",
  "scripts": {
    "db:reset": "ts-node src/database/resetDatabase.ts",
    "dev": "ts-node-dev --inspect --transpile-only --ignore-watch node_modules src/server.ts",
    "clean": "git clean -fd",
    "clean:dry": "git clean -nd",
    "build": "tsc",
    "start": "node dist/server.js",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/data-source.ts"
  },
  "keywords": [
    "api",
    "rest",
    "typescript",
    "typeorm",
    "mysql",
    "jwt"
  ],
  "author": "Lisandro Rezende",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.9.7",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "sqlite3": "^5.1.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}